# Public site origin (no trailing slash). Used for canonical URLs, OG tags,
# sitemap.xml, robots.txt, llms.txt, and JSON-LD `@id` fields.
NEXT_PUBLIC_SITE_URL=https://quantumaire.com

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX.
# Generated at https://analytics.google.com/. Leave unset to disable GA.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token, e.g. ABC123...
# Generated at https://search.google.com/search-console/welcome.
# Leave unset until you verify ownership.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
